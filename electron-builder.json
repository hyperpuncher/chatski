{
	"$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/refs/heads/master/packages/app-builder-lib/scheme.json",
	"appId": "com.chatski.app",
	"productName": "chatski",
	"directories": {
		"buildResources": "build"
	},
	"electronLanguages": ["en-US"],
	"files": [
		"out/**/*",
		"node_modules/impit/**/*",
		"node_modules/impit-linux-x64-gnu/**/*",
		"node_modules/impit-linux-x64-musl/**/*",
		"package.json"
	],
	"npmRebuild": true,
	"win": {
		"executableName": "chatski"
	},
	"nsis": {
		"artifactName": "${name}-${version}-setup.${ext}",
		"shortcutName": "${productName}",
		"uninstallDisplayName": "${productName}",
		"createDesktopShortcut": "always"
	},
	"mac": {
		"target": [
			{
				"target": "dir",
				"arch": ["x64", "arm64"]
			}
		],
		"notarize": false
	},
	"dmg": {
		"artifactName": "${name}-${version}.${ext}",
		"sign": false
	},
	"linux": {
		"target": ["AppImage"],
		"category": "Utility"
	},
	"appImage": {
		"artifactName": "${name}-${version}.${ext}"
	}
}
