{
	"name": "chatski",
	"version": "2.3.5",
	"private": true,
	"description": "chatski with your slop generators",
	"type": "module",
	"main": "./out/main/main.js",
	"scripts": {
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --incremental --tsgo",
		"check:watch": "svelte-kit sync && svelte-check --incremental --tsgo --watch",
		"format": "bun run format:oxfmt ; bun run format:prettier",
		"format:oxfmt": "bunx oxfmt",
		"format:prettier": "prettier --log-level error --write '**/*.svelte'",
		"lint": "bunx oxlint",
		"lint:fix": "bunx oxlint --fix",
		"icons": "./scripts/generate-icons.sh",
		"clean": "rm -rf node_modules/ .svelte-kit/ bun.lock out/ .vite/ dist/",
		"start": "electron-vite preview",
		"dev": "electron-vite dev",
		"prebuild": "vite build && electron-vite build",
		"build:unpack": "bun run prebuild && electron-builder --dir",
		"build:linux": "bun run prebuild && electron-builder --linux",
		"build:mac": "bun run prebuild && electron-builder --mac",
		"build:windows": "bun run prebuild && electron-builder --windows",
		"publish:linux": "bun run prebuild && electron-builder --linux --publish onTag",
		"publish:mac": "bun run prebuild && electron-builder --mac --publish onTag",
		"publish:windows": "bun run prebuild && electron-builder --windows --publish onTag"
	},
	"dependencies": {
		"impit": "^0.13.0"
	},
	"devDependencies": {
		"@ai-sdk/devtools": "^0.0.15",
		"@ai-sdk/mcp": "^1.0.36",
		"@ai-sdk/svelte": "^4.0.168",
		"@fontsource-variable/cascadia-code": "^5.2.2",
		"@fontsource-variable/inter": "^5.2.8",
		"@lucide/svelte": "^1.8.0",
		"@openrouter/ai-sdk-provider": "2.8.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.6.0",
		"@types/turndown": "^5.0.6",
		"@typescript/native-preview": "^7.0.0-dev.20260418.1",
		"ai": "^6.0.168",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"electron": "^41.2.1",
		"electron-builder": "^26.8.1",
		"electron-updater": "^6.8.3",
		"electron-vite": "^5.0.0",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rollup-plugin-visualizer": "^7.0.1",
		"runed": "^0.37.1",
		"svelte": "5.49.1",
		"svelte-check": "^4.4.6",
		"svelte-render-scan": "^1.1.0",
		"svelte-sonner": "^1.0.8",
		"svelte-streamdown": "^3.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"turndown": "^7.2.4",
		"tw-animate-css": "^1.4.0",
		"uuidv7": "^1.2.1",
		"vite": "^8.0.9",
		"zod": "^4.3.6"
	}
}
