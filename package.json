{
	"name": "chatski",
	"version": "0.0.1",
	"private": true,
	"description": "chatski with your slop generators",
	"type": "module",
	"main": "./out/main/main.js",
	"scripts": {
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --incremental --tsgo",
		"check:watch": "svelte-kit sync && svelte-check --incremental --tsgo --watch",
		"format": "bun run format:oxfmt ; bun run format:prettier",
		"format:oxfmt": "oxfmt",
		"format:prettier": "prettier --log-level error --write '**/*.svelte'",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"icons": "./scripts/generate-icons.sh",
		"clean": "rm -rf node_modules/ .svelte-kit/ bun.lock out/ .vite/ dist/",
		"start": "electron-vite preview",
		"dev": "electron-vite dev",
		"prebuild": "vite build && electron-vite build",
		"build:unpack": "bun run prebuild && electron-builder --dir",
		"build:linux": "bun run prebuild && electron-builder --linux",
		"build:mac": "bun run prebuild && electron-builder --mac",
		"build:windows": "bun run prebuild && electron-builder --windows"
	},
	"dependencies": {
		"impit": "^0.11.0"
	},
	"devDependencies": {
		"@ai-sdk/devtools": "^0.0.15",
		"@ai-sdk/mcp": "^1.0.25",
		"@ai-sdk/svelte": "^4.0.116",
		"@fontsource-variable/cascadia-code": "^5.2.2",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@openrouter/ai-sdk-provider": "2.3.3",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.5.0",
		"@types/turndown": "^5.0.6",
		"@typescript/native-preview": "^7.0.0-dev.20260319.1",
		"ai": "^6.0.116",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"electron": "^41.0.2",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"mode-watcher": "^1.1.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.55.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rollup-plugin-visualizer": "^7.0.1",
		"runed": "^0.37.1",
		"svelte": "5.49.1",
		"svelte-check": "^4.4.5",
		"svelte-render-scan": "^1.1.0",
		"svelte-sonner": "^1.0.8",
		"svelte-streamdown": "^3.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"turndown": "^7.2.2",
		"tw-animate-css": "^1.4.0",
		"uuidv7": "^1.1.0",
		"vite": "^8.0.1",
		"zod": "^4.3.6"
	}
}
